# Database Configuration
DATABASE_PATH=./data/reading-tracker.db

# Server Configuration
PORT=3003
BACKEND_PORT=3003
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Logging Configuration
LOG_LEVEL=info
LOG_TO_FILE=false
LOGS_PATH=./logs

# Raspberry Pi Configuration (set to true when deploying to Pi)
RASPBERRY_PI=false

# Frontend Configuration
# Leave VITE_API_URL empty to use same-origin /api.
# VITE_API_URL=http://localhost:3003/api
VITE_API_PROXY_TARGET=http://localhost:3003

# Optional: Custom paths
# DATA_BACKUP_PATH=./backups
# IMPORT_PATH=./imports
