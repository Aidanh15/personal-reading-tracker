# Production Environment Configuration
# Copy this file to .env.production and update values for your deployment

# Database Configuration
DATABASE_PATH=/app/data/reading-tracker.db

# Server Configuration
PORT=3003
APP_PORT=3003
# Bind to your Tailscale IP for private access, for example 100.x.y.z.
APP_BIND_ADDRESS=127.0.0.1
NODE_ENV=production
CORS_ORIGIN=http://127.0.0.1:3003

# Logging Configuration
LOG_LEVEL=info
LOG_TO_FILE=true
LOGS_PATH=/app/logs

# Raspberry Pi Configuration
RASPBERRY_PI=true

# Frontend Configuration
# Leave VITE_API_URL empty when the backend serves the built frontend.
# VITE_API_URL=http://your-tailscale-ip:3003/api

# Optional: Backup and import paths
# DATA_BACKUP_PATH=/app/backups
# IMPORT_PATH=/app/imports
