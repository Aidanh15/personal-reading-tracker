# SSD-Optimized Environment Configuration for Raspberry Pi
# Copy this file to .env.ssd and update values for your SSD deployment

# Application Configuration
NODE_ENV=production
APP_PORT=3003
# Bind to your Tailscale IP for private access only.
APP_BIND_ADDRESS=127.0.0.1

# Database Configuration - SSD Optimized
DATABASE_PATH=/app/data/reading-tracker.db
SQLITE_CACHE_SIZE=10000
SQLITE_TEMP_STORE=memory
SQLITE_SYNCHRONOUS=NORMAL
SQLITE_WAL_MODE=true

# Logging Configuration - Enhanced for SSD
LOG_LEVEL=info
LOGS_PATH=/app/logs

# CORS Configuration
CORS_ORIGIN=http://127.0.0.1:3003

# Node.js Optimization for SSD deployment
NODE_OPTIONS=--max-old-space-size=512 --max-semi-space-size=64
UV_THREADPOOL_SIZE=8

# Raspberry Pi Configuration
RASPBERRY_PI=true

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_HOURS=6

# Frontend Configuration
# Leave VITE_API_URL empty when the backend serves the built frontend.
# VITE_API_URL=http://your-tailscale-ip:3003/api

# Optional: Monitoring
ENABLE_MONITORING=false
MONITORING_PORT=9101

# Optional: Nginx Proxy
ENABLE_PROXY=false

# Optional: Automated Backups
ENABLE_BACKUP=true
